# =============================================================================
# Knowledge Agent Template - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# See docs/ENVIRONMENT.md for detailed descriptions.

# --- Authentication ----------------------------------------------------------

BETTER_AUTH_SECRET=          # Random secret for signing sessions (generate with: openssl rand -hex 32)
GOOGLE_CLIENT_ID=            # Google OAuth client ID
GOOGLE_CLIENT_SECRET=        # Google OAuth client secret

# --- AI ----------------------------------------------------------------------

OPENROUTER_API_KEY=          # OpenRouter API key (required) — get one at https://openrouter.ai/keys

# --- Sandbox & Sync ----------------------------------------------------------

# NUXT_GITHUB_SNAPSHOT_REPO= # Default snapshot repository (owner/repo format)
# NUXT_GITHUB_SNAPSHOT_BRANCH=main
# NUXT_GITHUB_TOKEN=         # Optional PAT override for snapshot git operations
#                           # If omitted, the app uses GitHub App installation tokens

# --- GitHub Bot (optional) ---------------------------------------------------

# NUXT_PUBLIC_GITHUB_APP_NAME=your-bot-name     # GitHub App name (used for install URL and bot username)
# NUXT_PUBLIC_GITHUB_BOT_TRIGGER=               # Override bot mention trigger (defaults to app name)
# NUXT_GITHUB_APP_ID=
# NUXT_GITHUB_APP_PRIVATE_KEY=
# NUXT_GITHUB_WEBHOOK_SECRET=

# --- Discord Bot (optional) --------------------------------------------------

# NUXT_PUBLIC_DISCORD_BOT_URL=               # Full Discord bot invite URL
# NUXT_DISCORD_BOT_TOKEN=
# NUXT_DISCORD_PUBLIC_KEY=
# NUXT_DISCORD_APPLICATION_ID=
# NUXT_DISCORD_MENTION_ROLE_IDS=

# --- YouTube (optional) ------------------------------------------------------

# NUXT_YOUTUBE_API_KEY=

# --- Storage (optional) ------------------------------------------------------

# BLOB_READ_WRITE_TOKEN=     # Vercel Blob token for file uploads

# --- State (optional) --------------------------------------------------------

# REDIS_URL=                  # Redis URL for bot state persistence (falls back to in-memory)

# --- Composio (optional — enables connecting SaaS tools: Google, Slack, Notion, etc.) ------

# COMPOSIO_API_KEY=             # Composio API key (get one at https://app.composio.dev)
# COMPOSIO_TOOLKIT_SLUGS=googlesuper  # Comma-separated toolkit slugs, e.g. "googlesuper,slack,notion"
# COMPOSIO_AUTH_CONFIG_ID=      # (optional) Your own OAuth app config ID for production OAuth
#                               # Without this, Composio's shared OAuth app is used (fine for testing)

# --- Email (Resend, required for invitations) ---------------------------------

RESEND_API_KEY=               # Resend API key for sending invitation emails
RESEND_FROM_EMAIL=noreply@yourdomain.com  # From email address for invitations
